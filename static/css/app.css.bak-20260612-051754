/* ============================================================================
   Skyward — soft topographic aesthetic.
   A mountain weather tool that should feel calm and trustworthy. Warm off-white
   paper base, soft slate ink, a muted blue-grey accent with a slate-teal
   secondary — the restful palette of a good topo map. Condensed display face
   over a clean humanist body. Legible in daylight, gentle on the eye.
   ============================================================================ */

@import url('https://fonts.googleapis.com/css2?family=Barlow+Semi+Condensed:wght@500;600;700&family=Barlow:wght@400;500;600&display=swap');

:root {
  /* Surfaces — warm paper, gently layered */
  --bg:          #f4f1ea;   /* warm off-white paper */
  --bg-raised:   #fbfaf6;   /* cards sit slightly brighter than the page */
  --bg-panel:    #fcfbf8;   /* the slide-up sheet */
  --bg-hover:    #ece8df;
  --line:        #d8d2c6;   /* soft pencil lines */
  --line-soft:   #e6e1d7;

  /* Ink — soft slate, never pure black */
  --ink:         #2f3a42;
  --ink-dim:     #5d6a72;
  --ink-faint:   #93999e;

  /* Accent — muted blue-grey, like distant ridgelines */
  --accent:      #5a7d9a;
  --accent-bright:#6f93b0;
  --accent-deep: #436076;

  /* Secondary — slate-teal, for quiet contrast */
  --accent2:     #5f8a82;

  /* Status / avalanche-style scale (also used by Winter Mode) */
  --good:        #5a9e78;   /* low / settled */
  --warn:        #d9a441;   /* moderate */
  --high:        #d98a45;   /* considerable */
  --danger:      #cf5b53;   /* high */
  --severe:      #8a5fb0;   /* very high — kept distinct, used sparingly */

  --radius:      10px;
  --radius-sm:   7px;
  --shadow:      0 6px 24px rgba(47,58,66,.12);
  --shadow-up:   0 -6px 24px rgba(47,58,66,.12);

  --nav-h:       62px;
  --display:     'Barlow Semi Condensed', system-ui, sans-serif;
  --body:        'Barlow', system-ui, sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  background: var(--bg);
  color: var(--ink);
  font-family: var(--body);
  -webkit-font-smoothing: antialiased;
  overscroll-behavior: none;
}

#app { height: 100vh; height: 100dvh; display: flex; flex-direction: column; }

/* The view stage fills everything above the bottom nav */
#view {
  position: relative;
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
}

/* ---- Display type, used for readings and headers ------------------------- */
.display { font-family: var(--display); letter-spacing: .01em; }
.eyebrow {
  font-family: var(--display);
  text-transform: uppercase;
  letter-spacing: .14em;
  font-size: .72rem;
  font-weight: 600;
  color: var(--accent);
}

/* ============================ MAP VIEW =================================== */
#map { position: absolute; inset: 0; background: #e8e4db; }

/* Leaflet light tweaks */
.leaflet-container { background: #e8e4db; font-family: var(--body); }
.leaflet-control-zoom a {
  background: var(--bg-raised) !important;
  color: var(--ink) !important;
  border-color: var(--line) !important;
}
.leaflet-control-zoom a:hover { background: var(--bg-hover) !important; }
.leaflet-bar { border: 1px solid var(--line) !important; box-shadow: var(--shadow) !important; }
.leaflet-control-attribution {
  background: rgba(251,250,246,.85) !important;
  color: var(--ink-faint) !important;
}
.leaflet-control-attribution a { color: var(--ink-dim) !important; }

/* The Investigate crosshair — fixed dead-centre over the map */
#crosshair {
  position: absolute;
  top: 50%; left: 50%;
  width: 46px; height: 46px;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 500;
}
#crosshair::before, #crosshair::after {
  content: ""; position: absolute; background: var(--accent-deep);
  box-shadow: 0 0 0 1px rgba(255,255,255,.7);
}
#crosshair::before { left: 50%; top: 0; width: 2px; height: 100%; transform: translateX(-50%); }
#crosshair::after  { top: 50%; left: 0; height: 2px; width: 100%; transform: translateY(-50%); }
#crosshair .ring {
  position: absolute; inset: 12px;
  border: 2px solid var(--accent-deep);
  border-radius: 50%;
  box-shadow: 0 0 0 1px rgba(255,255,255,.7), 0 0 10px rgba(90,125,154,.35);
}

/* Investigate button */
.fab {
  position: absolute;
  left: 50%; bottom: 22px;
  transform: translateX(-50%);
  z-index: 600;
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .85rem 1.6rem;
  background: var(--accent);
  color: #fff;
  font-family: var(--display);
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: .06em;
  text-transform: uppercase;
  border: none; border-radius: 100px;
  box-shadow: var(--shadow), 0 0 0 4px rgba(90,125,154,.15);
  cursor: pointer;
  transition: transform .12s ease, background .15s ease;
}
.fab:hover { background: var(--accent-bright); }
.fab:active { transform: translateX(-50%) scale(.96); }
.fab:disabled { opacity: .6; cursor: default; }

/* Map top bar: two rows — controls, then the layer toggles */
.map-topbar {
  position: absolute; top: 12px; left: 12px; right: 12px;
  z-index: 600;
  display: flex; flex-direction: column; gap: .4rem; align-items: stretch;
  pointer-events: none;
}
.topbar-row {
  display: flex; gap: .4rem; align-items: center; flex-wrap: wrap;
  pointer-events: none;
}
.topbar-row > * { pointer-events: auto; }
.area-select {
  flex: 1 1 140px;
  background: rgba(251,250,246,.94);
  color: var(--ink);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  padding: .6rem .8rem;
  font-family: var(--body); font-size: .9rem;
  backdrop-filter: blur(6px);
  box-shadow: var(--shadow);
}
.winter-toggle {
  display: inline-flex; align-items: center; gap: .35rem;
  background: rgba(251,250,246,.94);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  padding: .55rem .65rem;
  cursor: pointer; backdrop-filter: blur(6px);
  font-family: var(--display); font-weight: 600;
  font-size: .78rem; letter-spacing: .05em; text-transform: uppercase;
  color: var(--ink-dim);
  white-space: nowrap;
  box-shadow: var(--shadow);
}
.winter-toggle[aria-pressed="true"] {
  color: #fff; background: var(--accent2); border-color: var(--accent2);
}

/* Text-size control (A− / A / A+) — shares the topbar pill look */
.text-size {
  display: inline-flex; align-items: stretch;
  background: rgba(251,250,246,.94);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  overflow: hidden; backdrop-filter: blur(6px);
  box-shadow: var(--shadow);
}
.text-size button {
  background: none; border: none; cursor: pointer;
  padding: .5rem .6rem;
  font-family: var(--display); font-weight: 700;
  color: var(--ink-dim); line-height: 1;
  border-right: 1px solid var(--line-soft);
}
.text-size button:last-child { border-right: none; }
.text-size button:hover:not(:disabled) { background: var(--bg-hover); color: var(--ink); }
.text-size button:disabled { opacity: .35; cursor: default; }
.text-size #font-down { font-size: .8rem; }
.text-size #font-reset { font-size: .95rem; }
.text-size #font-up { font-size: 1.1rem; }

/* Segmented group: keeps the layer toggles visually joined even when the bar wraps */
.seg { display: inline-flex; align-items: stretch; }
.seg .winter-toggle { box-shadow: none; }
.seg .winter-toggle:first-child {
  border-top-right-radius: 0; border-bottom-right-radius: 0; border-right: none;
}
.seg .winter-toggle:not(:first-child):not(:last-child) {
  border-radius: 0; border-right: none;
}
.seg .winter-toggle:last-child {
  border-top-left-radius: 0; border-bottom-left-radius: 0;
}
.seg { box-shadow: var(--shadow); border-radius: var(--radius-sm); }

/* Topbar zoom buttons (replace Leaflet's corner +/− control) */
.zoom-ctl button {
  font-size: .78rem; letter-spacing: .05em; text-transform: uppercase;
  padding: .5rem .65rem;
}

/* ===================== DATA PANEL (slide-up sheet) ======================= */
#sheet {
  position: absolute; left: 0; right: 0; bottom: 0;
  z-index: 700;
  background: var(--bg-panel);
  border-top: 1px solid var(--line);
  border-radius: 18px 18px 0 0;
  box-shadow: var(--shadow-up);
  transform: translateY(100%);
  transition: transform .32s cubic-bezier(.22,.61,.36,1);
  max-height: 86%;
  display: flex; flex-direction: column;
}
#sheet.open { transform: translateY(0); }
#sheet.expanded { max-height: 92%; }

.sheet-grip {
  flex: 0 0 auto;
  padding: .7rem 0 .4rem;
  display: flex; justify-content: center;
  cursor: grab;
}
.sheet-grip span { width: 42px; height: 5px; border-radius: 3px; background: var(--line); }

.sheet-head {
  flex: 0 0 auto;
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 0 1.2rem .8rem;
  border-bottom: 1px solid var(--line-soft);
}
.sheet-head h2 { font-family: var(--display); font-weight: 700; font-size: 1.25rem; line-height: 1.1; }
.sheet-head .coords { color: var(--ink-faint); font-size: .8rem; margin-top: .15rem; }
.sheet-head .coords.place-named { color: var(--ink-dim); font-weight: 600; font-family: var(--display); }
.sheet-close {
  background: var(--bg-hover); border: 1px solid var(--line); color: var(--ink-dim);
  width: 34px; height: 34px; border-radius: 50%; cursor: pointer; font-size: 1.1rem;
  flex: 0 0 auto;
}

.sheet-body { flex: 1 1 auto; overflow-y: auto; padding: 1rem 1.2rem 1.4rem; }

/* Current conditions strip */
.now {
  display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;
  padding-bottom: 1rem; border-bottom: 1px solid var(--line-soft); margin-bottom: 1rem;
}
.now .temp { font-family: var(--display); font-weight: 700; font-size: 3.2rem; line-height: .9; }
.now .temp small { font-size: 1.2rem; color: var(--ink-dim); }
.now .stat { display: flex; flex-direction: column; }
.now .stat b { font-family: var(--display); font-size: 1.15rem; font-weight: 600; }
.now .stat span { font-size: .72rem; color: var(--ink-faint); text-transform: uppercase; letter-spacing: .08em; }

/* Morning / PM / Night triad */
.triad { display: grid; grid-template-columns: repeat(3, 1fr); gap: .6rem; margin-bottom: 1.1rem; }
.triad .slot {
  background: var(--bg-raised); border: 1px solid var(--line-soft);
  border-radius: var(--radius-sm); padding: .8rem .7rem; text-align: center;
}
.triad .slot .when { font-family: var(--display); font-size: .78rem; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); }
.triad .slot .t { font-family: var(--display); font-size: 1.7rem; font-weight: 700; margin: .2rem 0; }
.triad .slot .sub { font-size: .72rem; color: var(--ink-dim); }

.expand-hint {
  text-align: center; color: var(--ink-faint); font-size: .78rem;
  padding: .3rem 0 .8rem; letter-spacing: .04em;
}

/* Hourly table (revealed on expand) */
.hourly { display: none; }
#sheet.expanded .hourly { display: block; }
#sheet.expanded .triad-hint { display: none; }
.hourly h3 { font-family: var(--display); text-transform: uppercase; letter-spacing: .1em; font-size: .8rem; color: var(--ink-dim); margin: .4rem 0 .6rem; }
.hourly-row {
  display: grid; grid-template-columns: 56px 1fr auto auto; gap: .6rem; align-items: center;
  padding: .5rem .2rem; border-bottom: 1px solid var(--line-soft); font-size: .88rem;
}
.hourly-row .hr { font-family: var(--display); font-weight: 600; color: var(--ink-dim); }
.hourly-row .wx { color: var(--ink); }
.hourly-row .pp { color: var(--accent-deep); font-variant-numeric: tabular-nums; }
.hourly-row .wd { color: var(--ink-dim); font-variant-numeric: tabular-nums; }

/* Attribution footer in panels */
.attribution {
  margin-top: 1rem; padding-top: .8rem; border-top: 1px solid var(--line-soft);
  font-size: .76rem; color: var(--ink-faint);
}
.attribution a { color: var(--accent); text-decoration: none; }
.attribution a:hover { text-decoration: underline; }

/* States */
.sheet-state { padding: 2rem 1rem; text-align: center; color: var(--ink-dim); }
.spinner {
  width: 30px; height: 30px; margin: 0 auto 1rem;
  border: 3px solid var(--line); border-top-color: var(--accent);
  border-radius: 50%; animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.sheet-state .err-icon { font-size: 1.8rem; }

/* ============================ GENERIC VIEWS ============================== */
.scroll-view { position: absolute; inset: 0; overflow-y: auto; padding: 1.2rem 1.2rem calc(var(--nav-h) + 1.4rem); }
.view-head { margin-bottom: 1.2rem; }
.view-head h1 { font-family: var(--display); font-weight: 700; font-size: 1.7rem; }
.view-head p { color: var(--ink-dim); font-size: .92rem; margin-top: .25rem; }

/* Webcams grid */
.area-group { margin-bottom: 1.6rem; }
.area-group > h2 {
  font-family: var(--display); font-size: 1rem; letter-spacing: .06em;
  text-transform: uppercase; color: var(--accent);
  padding-bottom: .5rem; border-bottom: 1px solid var(--line-soft); margin-bottom: .8rem;
}
.cam-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: .7rem; }
.cam-card {
  background: var(--bg-raised); border: 1px solid var(--line-soft);
  border-radius: var(--radius-sm); padding: .8rem; cursor: pointer;
  transition: border-color .15s, transform .12s;
}
.cam-card:hover { border-color: var(--accent); transform: translateY(-2px); }
.cam-card .cam-thumb {
  aspect-ratio: 16/10; border-radius: 5px; margin-bottom: .55rem;
  overflow: hidden; position: relative;
  background: linear-gradient(135deg, #e9e4d9, #dfe6e4);
}
.cam-card .cam-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.cam-card .cam-thumb-empty {
  display: flex; align-items: center; justify-content: center;
  color: var(--ink-faint); font-size: 1.6rem;
}
.cam-card .cam-name { font-family: var(--display); font-weight: 600; font-size: .92rem; }
.cam-card .cam-note { color: var(--ink-faint); font-size: .76rem; margin-top: .15rem; line-height: 1.3; }
.cam-card .cam-fav { float: right; color: var(--ink-faint); cursor: pointer; font-size: 1.05rem; }
.cam-card .cam-fav.on { color: var(--accent); }

/* Library */
.module {
  background: var(--bg-raised); border: 1px solid var(--line-soft);
  border-radius: var(--radius); margin-bottom: .8rem; overflow: hidden;
}
.module-head {
  display: flex; align-items: center; gap: .9rem; padding: 1rem 1.1rem; cursor: pointer;
}
.module-head .num {
  flex: 0 0 auto; width: 34px; height: 34px; border-radius: 50%;
  display: grid; place-items: center;
  background: var(--accent); color: #fff;
  font-family: var(--display); font-weight: 700;
}
.module-head .mt { flex: 1 1 auto; }
.module-head .mt h2 { font-family: var(--display); font-size: 1.15rem; font-weight: 700; }
.module-head .mt p { color: var(--ink-dim); font-size: .82rem; margin-top: .1rem; }
.module-head .chev { color: var(--ink-faint); transition: transform .2s; }
.module.open .module-head .chev { transform: rotate(90deg); }
.module-body { display: none; padding: 0 1.1rem 1.1rem; }
.module.open .module-body { display: block; }
.topic { padding: .9rem 0; border-top: 1px solid var(--line-soft); }
.topic h3 { font-family: var(--display); font-size: 1rem; font-weight: 600; color: var(--accent-bright); margin-bottom: .35rem; }
.topic p { color: var(--ink-dim); font-size: .9rem; line-height: 1.55; }
.topic .srcs { margin-top: .5rem; display: flex; flex-direction: column; gap: .25rem; }
.topic .srcs a { color: var(--accent); font-size: .8rem; text-decoration: none; }
.topic .srcs a::before { content: "→ "; color: var(--ink-faint); }
.topic .srcs a:hover { text-decoration: underline; }

/* ============================ FORECAST VIEW ============================== */
.area-list { display: flex; flex-direction: column; gap: .4rem; margin-bottom: 1rem; }
.area-row {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--bg-raised); border: 1px solid var(--line-soft);
  border-radius: var(--radius-sm); padding: .85rem 1rem; cursor: pointer;
  font-family: var(--body); text-align: left; transition: border-color .15s, transform .12s;
}
.area-row:hover { border-color: var(--accent); transform: translateX(2px); }
.area-row .area-name { font-family: var(--display); font-weight: 600; font-size: 1rem; color: var(--ink); }
.area-row .area-go { color: var(--accent); font-family: var(--display); font-size: .85rem; }

.fc-links { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 1.2rem; }
.fc-link {
  background: var(--bg-raised); border: 1px solid var(--line-soft);
  border-radius: 100px; padding: .5rem .9rem; cursor: pointer;
  color: var(--accent-deep); font-size: .85rem; font-family: var(--display); font-weight: 600;
}
.fc-link:hover { border-color: var(--accent); }

.fc-card {
  background: var(--bg-raised); border: 1px solid var(--line-soft);
  border-radius: var(--radius); padding: 1.1rem 1.2rem; margin-top: .4rem;
}
.fc-area-title { font-family: var(--display); font-weight: 700; font-size: 1.4rem; }
.fc-headline {
  font-family: var(--display); font-size: 1.05rem; font-weight: 600; color: var(--accent-deep);
  margin: .5rem 0 .8rem; padding: .6rem .8rem; background: var(--bg); border-radius: var(--radius-sm);
  border-left: 3px solid var(--accent);
}
.fc-summary { color: var(--ink-dim); font-size: .88rem; line-height: 1.5; margin-bottom: 1rem; }
.fc-day { padding-top: .8rem; margin-top: .8rem; border-top: 1px solid var(--line-soft); }
.fc-date { font-family: var(--display); font-weight: 700; font-size: 1.05rem; color: var(--accent-deep); margin-bottom: .6rem; }
.fc-field { margin-bottom: .7rem; }
.fc-label {
  font-family: var(--display); text-transform: uppercase; letter-spacing: .08em;
  font-size: .74rem; color: var(--accent); font-weight: 600; margin-bottom: .15rem;
}
.fc-text { color: var(--ink); font-size: .9rem; line-height: 1.5; }
.fc-outlook { margin-top: 1rem; padding-top: .9rem; border-top: 1px solid var(--line-soft); }
.fc-outlook h3 { font-family: var(--display); font-size: .85rem; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-dim); margin-bottom: .4rem; }
.fc-outlook p { color: var(--ink-dim); font-size: .88rem; line-height: 1.55; }
.fc-summit {
  margin-top: 1rem; padding: .9rem 1rem; border-radius: var(--radius-sm);
  background: var(--bg); border: 1px solid var(--line-soft);
}
.fc-summit h3 { font-family: var(--display); font-size: .9rem; text-transform: uppercase; letter-spacing: .06em; color: var(--accent2); margin-bottom: .35rem; }
.fc-summit p { color: var(--ink-dim); font-size: .85rem; line-height: 1.5; margin-bottom: .6rem; }
.fc-summit .fc-links { margin: 0; }
.fab-inline {
  margin-top: .8rem; background: var(--accent); color: #fff; border: none;
  border-radius: 100px; padding: .6rem 1.2rem; font-family: var(--display);
  font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: .05em; font-size: .85rem;
}

/* Peak pins on the map (Leaflet divIcon) */
.peak-pin { display: flex; align-items: center; gap: 4px; white-space: nowrap; }
.peak-dot {
  width: 9px; height: 9px; border-radius: 50%;
  background: var(--accent); border: 1.5px solid #fff;
  box-shadow: 0 1px 3px rgba(47,58,66,.4); flex: 0 0 auto;
}
.peak-label {
  font-family: var(--display); font-size: .72rem; font-weight: 600;
  color: var(--ink); background: rgba(251,250,246,.82);
  padding: 0 4px; border-radius: 3px; backdrop-filter: blur(2px);
}
body.winter .peak-dot { background: var(--accent); }

/* Small mountains (Corbetts/Grahams): distinct slate-teal, hollow marker */
.small-pin .peak-dot {
  background: #fbfaf6; border: 2px solid var(--accent2);
  width: 8px; height: 8px;
}
.small-pin .peak-label { color: var(--accent2); }

/* Crags (UKC, year-round): warm rock-brown diamond */
.crag-pin .peak-dot {
  background: #8a5a3c; border: 1.5px solid #fff;
  width: 8px; height: 8px; border-radius: 2px;
  transform: rotate(45deg);
}
.crag-pin .peak-label { color: #8a5a3c; }

/* ============================ BOTTOM NAV ================================= */
#nav {
  flex: 0 0 var(--nav-h);
  display: grid; grid-template-columns: repeat(4, 1fr);
  background: var(--bg-raised);
  border-top: 1px solid var(--line);
}
.nav-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px;
  background: none; border: none; cursor: pointer; color: var(--ink-faint);
  font-family: var(--display); font-size: .72rem; letter-spacing: .06em; text-transform: uppercase;
  transition: color .15s;
}
.nav-btn svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.8; }
.nav-btn.active { color: var(--accent); }

/* In-app viewer overlay (external links). z-index very high so nothing — not
   even Leaflet's own controls (separate stacking context) — bleeds through. */
#iab {
  position: absolute; inset: 0; z-index: 2000; background: var(--bg);
  display: none; flex-direction: column;
}
#iab.open { display: flex; }
.iab-bar {
  flex: 0 0 auto; display: flex; align-items: center; gap: .7rem;
  padding: .7rem 1rem; background: var(--bg-raised); border-bottom: 1px solid var(--line);
}
.iab-bar .iab-url { flex: 1 1 auto; color: var(--ink-dim); font-size: .82rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.iab-done {
  background: var(--accent); color: #fff; border: none; border-radius: 100px;
  padding: .45rem 1.1rem; font-family: var(--display); font-weight: 700; cursor: pointer;
  text-transform: uppercase; letter-spacing: .05em; font-size: .82rem;
}
.iab-stage { flex: 1 1 auto; min-height: 0; position: relative; background: var(--bg); }
.iab-frame { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }

/* The launch card shown for external (non-embeddable) links */
.iab-card {
  max-width: 380px; margin: 0 auto; padding: 3rem 1.6rem;
  display: flex; flex-direction: column; align-items: center; text-align: center;
  height: 100%; justify-content: center;
}
.iab-card-icon {
  width: 64px; height: 64px; border-radius: 50%;
  display: grid; place-items: center; margin-bottom: 1.2rem;
  background: var(--bg-raised); border: 1px solid var(--line);
  font-size: 1.8rem; color: var(--accent);
}
.iab-card h2 { font-family: var(--display); font-weight: 700; font-size: 1.35rem; margin-bottom: .7rem; }
.iab-card p { color: var(--ink-dim); font-size: .92rem; line-height: 1.55; margin-bottom: 1.6rem; }
.iab-launch {
  text-decoration: none; background: var(--accent); color: #fff;
  border-radius: 100px; padding: .85rem 1.8rem;
  font-family: var(--display); font-weight: 700; font-size: 1rem;
  text-transform: uppercase; letter-spacing: .05em;
  box-shadow: var(--shadow);
}
.iab-launch:hover { background: var(--accent-bright); }
.iab-host { margin-top: 1rem; color: var(--ink-faint); font-size: .8rem; }

/* Winter mode body tint */
/* Winter mode: shift the accent cooler. Page stays paper-light. */
body.winter { --accent: #4a7fa5; --accent-bright: #5e93b8; --accent-deep: #356183; --accent2: #4a7fa5; }
body.winter .fab { color: #fff; }
body.winter .module-head .num { color: #fff; }

/* Toast for transient messages */
#toast {
  position: absolute; left: 50%; bottom: calc(var(--nav-h) + 16px);
  transform: translateX(-50%) translateY(20px);
  background: var(--danger); color: #fff; padding: .7rem 1.1rem; border-radius: 100px;
  font-size: .88rem; z-index: 800; opacity: 0; pointer-events: none;
  transition: opacity .25s, transform .25s; box-shadow: var(--shadow);
  max-width: 90%; text-align: center;
}
#toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* Wide screens (Mac, tablet landscape): use the full window. The map goes
   edge-to-edge; the reading views (Forecast/Webcams/Library) keep a
   comfortable measure by centring their content; the bottom sheet becomes a
   centred panel rather than a wall-to-wall strip. Everything is rem-based,
   so the A−/A+ text-size control scales the measure too. */
@media (min-width: 720px) {
  .scroll-view {
    padding-left:  max(1.2rem, calc((100% - 64rem) / 2));
    padding-right: max(1.2rem, calc((100% - 64rem) / 2));
  }
  #sheet {
    max-width: 40rem;
    margin: 0 auto;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
  }
}
