.sais-hazard.lvl-4 { background: var(--danger, #c0452f); }
.sais-hazard.lvl-5 { background: var(--severe, #7a1f1f); }

.sais-desc {
  font-size: .9rem;
  margin: 0 0 .75rem;
}
.sais-period {
  font-size: .8rem;
  opacity: .75;
  margin-bottom: .5rem;
}
.sais-field { margin-bottom: .75rem; }
.sais-field h4 {
  margin: 0 0 .2rem;
  font-size: .78rem;
  text-transform: uppercase;
  letter-spacing: .04em;
  opacity: .75;
