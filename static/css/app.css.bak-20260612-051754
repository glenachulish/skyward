  position: absolute;
  left: 50%; transform: translateX(-50%);
  top: 4.2rem;
  z-index: 1200;               /* above Leaflet panes, below the iab overlay (2000) */
  max-width: min(34rem, 92%);
  display: flex; align-items: center; gap: .6rem;
  background: var(--paper, #f4f1ea);
  color: var(--ink, #2f3a42);
  border: 1px solid var(--accent, #5a7d9a);
  border-radius: .6rem;
  padding: .55rem .75rem;
  font-size: .85rem;
  box-shadow: 0 2px 10px rgba(47, 58, 66, .18);
}
.sais-banner button {
  border: none; background: none; cursor: pointer;
  color: var(--ink, #2f3a42); font-size: 1rem; line-height: 1;
  padding: .15rem .3rem; flex: 0 0 auto;
